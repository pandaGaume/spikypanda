{
    "name": "@spiky-panda/runtime",
    "version": "0.1.0",
    "description": "ONNX-like compute graph runtime for SpikyPanda neural networks",
    "private": true,
    "main": "dist/index",
    "module": "dist/index",
    "esnext": "dist/index",
    "types": "dist/index",
    "files": ["dist", "src"],
    "scripts": {
        "build": "npm run clean && npm run compile",
        "clean": "rimraf dist && rimraf tsconfig.build.tsbuildinfo",
        "compile": "npm run compile:source",
        "compile:source": "tsc -b tsconfig.build.json",
        "watch:source": "tsc -b tsconfig.build.json -w"
    },
    "sideEffects": false,
    "devDependencies": {
        "rimraf": "~6.0.1"
    }
}
