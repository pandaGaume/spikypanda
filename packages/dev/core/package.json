{
    "name": "@spiky-panda/core",
    "version": "0.2.0",
    "description": "Core library for Spikypanda - geometry, graph, and neural network primitives",
    "type": "module",
    "main": "dist/index.js",
    "module": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "default": "./dist/index.js"
        }
    },
    "files": [
        "dist"
    ],
    "sideEffects": false,
    "scripts": {
        "build": "npm run clean && npm run compile",
        "clean": "rimraf dist bundle && rimraf tsconfig.build.tsbuildinfo",
        "compile": "npm run compile:source",
        "compile:source": "tsc -b tsconfig.build.json",
        "watch:source": "tsc -b tsconfig.build.json -w",
        "bundle": "webpack --config webpack.config.cjs --mode production",
        "bundle:dev": "webpack --config webpack.config.cjs --mode development",
        "bundle:watch": "webpack --config webpack.config.cjs --mode development --watch",
        "prepublishOnly": "npm run build"
    },
    "keywords": [
        "spikypanda",
        "geometry",
        "graph",
        "neural-network",
        "spiking-neural-network"
    ],
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/GuillaumePelletier/spikypanda.git",
        "directory": "packages/dev/core"
    },
    "peerDependencies": {
        "reflect-metadata": "^0.2.2",
        "tslib": "^2.8.1"
    },
    "devDependencies": {
        "rimraf": "~6.0.1",
        "ts-loader": "^9.5.0"
    }
}
