# Ignore node_modules and dependencies
node_modules/
package-lock.json
pnpm-lock.yaml
yarn.lock

# Ignore TypeScript build outputs
dist/
build/
bundle/
out/
*.js
*.js.map
*.d.ts

# Ignore IDE/editor-specific files
.vscode/
.idea/
*.code-workspace

# Ignore system files
.DS_Store
Thumbs.db

# Ignore logs and temporary files
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# Ignore TypeScript cache and ESLint cache
*.tsbuildinfo
.eslintcache

# Ignore WebGPU/WebGL specific cache files
.cache/
.gpu_cache/

# Ignore test coverage
coverage/

# Ignore environment files
.env
.env.local
.env.*.local
